FROM python:3.12-slim-bookworm

WORKDIR /app

# Keep image small and deterministic.
ENV PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PIP_NO_CACHE_DIR=1 \
    PYTHONDONTWRITEBYTECODE=1

# Needed because requirements include a git-based dependency URL.
RUN apt-get update && \
    apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*

# Install dependency layer first for better Docker cache reuse.
COPY requirements.txt ./
RUN python -m pip install --upgrade pip setuptools wheel build && \
    pip install -r requirements.txt

# Copy project and build distributable artifacts.
COPY . .

CMD ["python", "-m", "build"]

